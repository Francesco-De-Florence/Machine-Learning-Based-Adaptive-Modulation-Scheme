   "source": [
    "## 2️⃣ Dataset Generation\n",
    "\n",
    "We simulate a realistic wireless channel dataset with SNR and BER as features, and the corresponding optimal modulation scheme as the label.\n",
    "\n",
    "### BER–SNR Relationship\n",
    "The BER for each modulation scheme is derived from standard formulas:\n",
    "- **BPSK:** $P_e = Q(\\sqrt{2 \\cdot E_b/N_0})$\n",
    "- **QPSK:** $P_e = Q(\\sqrt{2 \\cdot E_b/N_0})$ (same as BPSK per bit)\n",
    "- **16-QAM:** $P_e \\approx 3/8 \\cdot \\text{erfc}(\\sqrt{E_s/(10N_0)})$\n",
    "- **64-QAM:** Higher order, needs much higher SNR"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from scipy.special import erfc\n",
    "\n",
    "def Q_func(x):\n",
    "    \"\"\"Q-function (tail probability of standard normal)\"\"\"\n",
    "    return 0.5 * erfc(x / np.sqrt(2))\n",
    "\n",
    "def ber_bpsk(snr_db):\n",
    "    snr_lin = 10 ** (snr_db / 10)\n",
    "    return Q_func(np.sqrt(2 * snr_lin))\n",
    "\n",
    "def ber_qpsk(snr_db):\n",
    "    snr_lin = 10 ** (snr_db / 10)\n",
    "    return Q_func(np.sqrt(2 * snr_lin))\n",
    "\n",
    "def ber_16qam(snr_db):\n",
    "    snr_lin = 10 ** (snr_db / 10)\n",
    "    return (3/8) * erfc(np.sqrt(snr_lin / 10))\n",
    "\n",
    "def ber_64qam(snr_db):\n",
    "    snr_lin = 10 ** (snr_db / 10)\n",
    "    return (7/24) * erfc(np.sqrt(snr_lin / 42))\n",
    "\n",
    "def assign_modulation(snr_db, ber):\n",
    "    \"\"\"\n",
    "    Assign optimal modulation based on SNR and BER thresholds.\n",
    "    Strategy: use highest-order modulation that keeps BER < 1e-3\n",
    "    \"\"\"\n",
    "    BER_THRESHOLD = 1e-3  # Maximum acceptable BER\n",
    "    \n",
    "    if snr_db < 5 or ber > 1e-2:\n",
    "        return 'BPSK'\n",
    "    elif snr_db < 10 or ber > 5e-3:\n",
    "        return 'QPSK'\n",
    "    elif snr_db < 20 or ber > 1e-3:\n",
    "        return '16-QAM'\n",
    "    else:\n",
    "        return '64-QAM'\n",
    "\n",
    "# ─── Generate Dataset ──────────────────────────────────────────────────────────\n",
    "N_SAMPLES = 5000\n",
    "\n",
    "snr_values  = np.random.uniform(-5, 35, N_SAMPLES)       # SNR range: -5 to 35 dB\n",
    "noise_level = np.random.normal(0, 0.5, N_SAMPLES)         # Realistic channel noise\n",
    "\n",
    "# Compute BER based on dominant modulation at each SNR, plus noise\n",
    "ber_values = np.array([\n",
    "    np.clip(\n",
    "        ber_bpsk(snr) * (1 + abs(noise_level[i])),\n",
    "        1e-7, 0.5\n",
    "    )\n",
    "    for i, snr in enumerate(snr_values)\n",
    "])\n",
    "\n",
    "# Assign labels\n",
    "modulations = np.array([\n",
    "    assign_modulation(snr_values[i], ber_values[i])\n",
    "    for i in range(N_SAMPLES)\n",
    "])\n",
    "\n",
    "# Build DataFrame\n",
    "df = pd.DataFrame({\n",
    "    'SNR_dB'     : np.round(snr_values, 3),\n",
    "    'BER'        : np.round(ber_values, 8),\n",
    "    'log10_BER'  : np.round(np.log10(np.clip(ber_values, 1e-10, 1)), 4),\n",
    "    'Modulation' : modulations\n",
    "})\n",
    "\n",
    "print('📊 Dataset Summary')\n",
    "print('='*50)\n",
    "print(df.describe().round(4))\n",
    "print(f'\\n📦 Class Distribution:')\n",
    "print(df['Modulation'].value_counts())"
   ]
  },
