    "## 4️⃣ Data Preprocessing & Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Feature Engineering ──────────────────────────────────────────────────────\n",
    "df['SNR_BER_product']  = df['SNR_dB'] * (-df['log10_BER'])   # Higher = better channel\n",
    "df['SNR_squared']      = df['SNR_dB'] ** 2\n",
    "df['BER_log_abs']      = df['log10_BER'].abs()\n",
    "\n",
    "FEATURES = ['SNR_dB', 'log10_BER', 'SNR_BER_product', 'SNR_squared', 'BER_log_abs']\n",
    "TARGET   = 'Modulation'\n",
    "\n",
    "X = df[FEATURES].values\n",
    "y = df[TARGET].values\n",
    "\n",
    "# ─── Encode labels ─────────────────────────────────────────────────────────────\n",
    "le = LabelEncoder()\n",
    "y_enc = le.fit_transform(y)\n",
    "print('Class mapping:', dict(zip(le.classes_, le.transform(le.classes_))))\n",
    "\n",
    "# ─── Train/Val/Test Split ──────────────────────────────────────────────────────\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y_enc, test_size=0.20, random_state=42, stratify=y_enc\n",
    ")\n",
    "X_train, X_val, y_train, y_val = train_test_split(\n",
    "    X_train, y_train, test_size=0.15, random_state=42, stratify=y_train\n",
    ")\n",
    "\n",
    "print(f'\\n📐 Dataset splits:')\n",
    "print(f'  Training  : {X_train.shape[0]} samples')\n",
    "print(f'  Validation: {X_val.shape[0]} samples')\n",
    "print(f'  Test      : {X_test.shape[0]} samples')\n",
    "\n",
    "# ─── Feature correlation heatmap ───────────────────────────────────────────────\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "corr_df = df[FEATURES + [TARGET]].copy()\n",
    "corr_df['Mod_encoded'] = y_enc\n",
    "sns.heatmap(corr_df[FEATURES + ['Mod_encoded']].corr(),\n",
    "            annot=True, fmt='.2f', cmap='RdYlGn', center=0,\n",
    "            ax=ax1, square=True)\n",
    "ax1.set_title('Feature Correlation Matrix')\n",
    "\n",
    "# Box plot: SNR per modulation\n",
    "mod_order = ['BPSK', 'QPSK', '16-QAM', '64-QAM']\n",
    "df['Modulation_ord'] = pd.Categorical(df['Modulation'], categories=mod_order, ordered=True)\n",
    "bp = df.sort_values('Modulation_ord').boxplot(\n",
    "    column='SNR_dB', by='Modulation_ord', ax=ax2, patch_artist=True,\n",
    "    boxprops=dict(facecolor='#3498DB', alpha=0.6),\n",
    "    medianprops=dict(color='#E74C3C', linewidth=2)\n",
    ")\n",
    "ax2.set_title('SNR Range per Modulation Class')\n",
    "ax2.set_xlabel('Modulation');  ax2.set_ylabel('SNR (dB)')\n",
    "plt.suptitle('')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "print('✅ Preprocessing complete.')"
   ]
