   "source": [
    "fig, axes = plt.subplots(2, 3, figsize=(18, 11))\n",
    "fig.suptitle(f'Model Evaluation — Best: {best_name}', fontsize=14, fontweight='bold')\n",
    "\n",
    "class_names = le.classes_\n",
    "y_pred_best = best_model.predict(X_test)\n",
    "\n",
    "# ── Plot 1: Confusion matrix ─────────────────────────────────────────────────\n",
    "ax = axes[0, 0]\n",
    "cm = confusion_matrix(y_test, y_pred_best)\n",
    "disp = ConfusionMatrixDisplay(cm, display_labels=class_names)\n",
    "disp.plot(ax=ax, colorbar=False, cmap='Blues')\n",
    "ax.set_title(f'Confusion Matrix – {best_name}')\n",
    "\n",
    "# ── Plot 2: Per-class precision / recall ──────────────────────────────────────\n",
    "ax = axes[0, 1]\n",
    "from sklearn.metrics import precision_recall_fscore_support\n",
    "prec, rec, f1, _ = precision_recall_fscore_support(y_test, y_pred_best)\n",
    "x_pos = np.arange(len(class_names))\n",
    "width = 0.25\n",
    "ax.bar(x_pos - width, prec, width, label='Precision', color='#3498DB', alpha=0.85)\n",
    "ax.bar(x_pos,         rec,  width, label='Recall',    color='#2ECC71', alpha=0.85)\n",
    "ax.bar(x_pos + width, f1,   width, label='F1-Score',  color='#E74C3C', alpha=0.85)\n",
    "ax.set_xticks(x_pos); ax.set_xticklabels(class_names)\n",
    "ax.set_ylim([0, 1.1]);  ax.set_ylabel('Score')\n",
    "ax.set_title('Per-Class Precision / Recall / F1')\n",
    "ax.legend(); ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "# ── Plot 3: Accuracy comparison bar chart ─────────────────────────────────────\n",
    "ax = axes[0, 2]\n",
    "model_names   = list(results.keys())\n",
    "test_accs     = [results[m]['test_acc']  for m in model_names]\n",
    "val_accs      = [results[m]['val_acc']   for m in model_names]\n",
    "short_names   = ['RF', 'GB', 'SVM', 'MLP']\n",
    "x2 = np.arange(len(model_names))\n",
    "ax.bar(x2 - 0.2, val_accs,  0.35, label='Val Accuracy',  color='#9B59B6', alpha=0.85)\n",
    "ax.bar(x2 + 0.2, test_accs, 0.35, label='Test Accuracy', color='#1ABC9C', alpha=0.85)\n",
    "ax.set_xticks(x2); ax.set_xticklabels(short_names)\n",
    "ax.set_ylim([0.9, 1.01]); ax.set_ylabel('Accuracy')\n",
    "ax.set_title('Model Accuracy Comparison')\n",
    "ax.legend(); ax.grid(axis='y', alpha=0.3)\n",
    "for i, (v, t) in enumerate(zip(val_accs, test_accs)):\n",
    "    ax.text(i - 0.2, v + 0.001, f'{v:.3f}', ha='center', fontsize=8)\n",
    "    ax.text(i + 0.2, t + 0.001, f'{t:.3f}', ha='center', fontsize=8)\n",
    "\n",
    "# ── Plot 4: Decision boundary (2D projection) ─────────────────────────────────\n",
    "ax = axes[1, 0]\n",
    "# Use only SNR_dB vs log10_BER for the 2D projection\n",
    "scaler_2d = StandardScaler()\n",
    "X_2d = scaler_2d.fit_transform(X[:, :2])\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier as RFC\n",
    "clf_2d = RFC(n_estimators=100, random_state=42, n_jobs=-1)\n",
    "clf_2d.fit(X_2d, y_enc)\n",
    "\n",
    "h = 0.05\n",
    "x_min, x_max = X_2d[:, 0].min() - 0.5, X_2d[:, 0].max() + 0.5\n",
    "y_min, y_max = X_2d[:, 1].min() - 0.5, X_2d[:, 1].max() + 0.5\n",
    "xx, yy = np.meshgrid(np.arange(x_min, x_max, h), np.arange(y_min, y_max, h))\n",
    "Z = clf_2d.predict(np.c_[xx.ravel(), yy.ravel()])\n",
    "Z = Z.reshape(xx.shape)\n",
    "\n",
    "cmap_bg  = plt.cm.get_cmap('Pastel1', 4)\n",
    "cmap_pts = plt.cm.get_cmap('Set1',    4)\n",
    "ax.contourf(xx, yy, Z, alpha=0.4, cmap=cmap_bg)\n",
    "scatter = ax.scatter(X_2d[:500, 0], X_2d[:500, 1], c=y_enc[:500],\n",
    "                     cmap=cmap_pts, s=8, alpha=0.7, edgecolors='none')\n",
    "patches = [mpatches.Patch(color=cmap_pts(i), label=c)\n",
    "           for i, c in enumerate(class_names)]\n",
    "ax.legend(handles=patches, fontsize=8)\n",
    "ax.set_xlabel('SNR (normalised)'); ax.set_ylabel('log₁₀(BER) (normalised)')\n",
    "ax.set_title('Decision Boundary (2D projection)')\n",
    "\n",
    "# ── Plot 5: Feature importance (RF) ───────────────────────────────────────────\n",
    "ax = axes[1, 1]\n",
    "rf_model = trained_models['Random Forest'].named_steps['clf']\n",
    "importances = rf_model.feature_importances_\n",
    "sorted_idx  = np.argsort(importances)[::-1]\n",
    "bars = ax.bar(range(len(FEATURES)),\n",
    "              importances[sorted_idx],\n",
    "              color=['#3498DB', '#E74C3C', '#2ECC71', '#F39C12', '#9B59B6'],\n",
    "              alpha=0.85, edgecolor='white')\n",
    "ax.set_xticks(range(len(FEATURES)))\n",
    "ax.set_xticklabels([FEATURES[i] for i in sorted_idx], rotation=20, ha='right', fontsize=9)\n",
    "ax.set_ylabel('Importance');  ax.set_title('Feature Importance (Random Forest)')\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "# ── Plot 6: Training time comparison ──────────────────────────────────────────\n",
    "ax = axes[1, 2]\n",
    "times = [results[m]['time'] for m in model_names]\n",
    "bars = ax.barh(short_names, times,\n",
    "               color=['#3498DB', '#E74C3C', '#2ECC71', '#F39C12'], alpha=0.85)\n",
    "ax.set_xlabel('Training Time (seconds)');  ax.set_title('Training Time Comparison')\n",
    "for bar, t in zip(bars, times):\n",
    "    ax.text(bar.get_width() + 0.01, bar.get_y() + bar.get_height()/2,\n",
    "            f'{t:.2f}s', va='center', fontsize=9)\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('model_evaluation.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('\\n📋 Full Classification Report:')\n",
    "print(classification_report(y_test, y_pred_best, target_names=class_names))"
   ]
  },
