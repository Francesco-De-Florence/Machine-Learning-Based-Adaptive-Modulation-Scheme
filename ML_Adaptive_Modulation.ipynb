    "## 5️⃣ Model Training — Multiple Classifiers\n",
    "\n",
    "We train four different ML classifiers and compare their performance:\n",
    "1. **Random Forest** — ensemble of decision trees\n",
    "2. **Gradient Boosting** — sequential boosting\n",
    "3. **Support Vector Machine (RBF kernel)**\n",
    "4. **Multi-Layer Perceptron (Neural Network)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "import time\n",
    "\n",
    "# ─── Define classifiers ────────────────────────────────────────────────────────\n",
    "classifiers = {\n",
    "    'Random Forest': Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('clf', RandomForestClassifier(\n",
    "            n_estimators=200, max_depth=None,\n",
    "            min_samples_split=2, random_state=42, n_jobs=-1\n",
    "        ))\n",
    "    ]),\n",
    "    'Gradient Boosting': Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('clf', GradientBoostingClassifier(\n",
    "            n_estimators=150, learning_rate=0.1,\n",
    "            max_depth=5, random_state=42\n",
    "        ))\n",
    "    ]),\n",
    "    'SVM (RBF)': Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('clf', SVC(kernel='rbf', C=10, gamma='scale',\n",
    "                    probability=True, random_state=42))\n",
    "    ]),\n",
    "    'MLP Neural Network': Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('clf', MLPClassifier(\n",
    "            hidden_layer_sizes=(128, 64, 32),\n",
    "            activation='relu', solver='adam',\n",
    "            max_iter=500, random_state=42,\n",
    "            early_stopping=True, validation_fraction=0.1\n",
    "        ))\n",
    "    ])\n",
    "}\n",
    "\n",
    "# ─── Train and evaluate all models ─────────────────────────────────────────────\n",
    "results = {}\n",
    "trained_models = {}\n",
    "\n",
    "print('🚀 Training models...\\n')\n",
    "print(f'{'Model':<22} {'Train Acc':>10} {'Val Acc':>10} {'Test Acc':>10} {'Time (s)':>10}')\n",
    "print('-' * 65)\n",
    "\n",
    "for name, pipeline in classifiers.items():\n",
    "    t0 = time.time()\n",
    "    pipeline.fit(X_train, y_train)\n",
    "    elapsed = time.time() - t0\n",
    "\n",
    "    train_acc = accuracy_score(y_train, pipeline.predict(X_train))\n",
    "    val_acc   = accuracy_score(y_val,   pipeline.predict(X_val))\n",
    "    test_acc  = accuracy_score(y_test,  pipeline.predict(X_test))\n",
    "\n",
    "    results[name] = {\n",
    "        'train_acc': train_acc, 'val_acc': val_acc,\n",
    "        'test_acc' : test_acc,  'time'   : elapsed\n",
    "    }\n",
    "    trained_models[name] = pipeline\n",
    "    print(f'{name:<22} {train_acc:>10.4f} {val_acc:>10.4f} {test_acc:>10.4f} {elapsed:>10.2f}')\n",
    "\n",
    "# ─── Select best model ─────────────────────────────────────────────────────────\n",
    "best_name  = max(results, key=lambda k: results[k]['val_acc'])\n",
    "best_model = trained_models[best_name]\n",
    "print(f'\\n🏆 Best model: {best_name} (val accuracy = {results[best_name][\"val_acc\"]:.4f})')"
   ]
  },
